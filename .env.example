# --- Application ---
NODE_ENV=development
APP_URL=http://localhost:3000
SESSION_SECRET=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-another-long-random-string

# --- Database ---
DATABASE_URL=postgresql://jmc:jmc@db:5432/jmc?schema=public

# --- Redis (queue + session revocation) ---
REDIS_URL=redis://redis:6379

# --- SMTP (OTP delivery) ---
# Dev: pakai MailHog (lihat email di http://localhost:8025)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="JMC HRD <no-reply@jmc.local>"
# Prod Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_USER=email@gmail.com SMTP_PASS=app-password
# Prod Resend: SMTP_HOST=smtp.resend.com SMTP_PORT=587 SMTP_USER=resend SMTP_PASS=re_xxx

# --- Office (referensi perhitungan jarak default) ---
OFFICE_DEFAULT_LAT=-7.797068
OFFICE_DEFAULT_LNG=110.370529
