// Skema Prisma untuk Aplikasi HRD JMC
// Mengacu pada ERD.md. Update keduanya bersamaan saat ada perubahan.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ AUTH ============

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique // superadmin | manager_hrd | admin_hrd
  description String?
  users       User[]
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("roles")
}

model User {
  id            Int        @id @default(autoincrement())
  employeeId    Int?       @unique @map("employee_id")
  employee      Employee?  @relation(fields: [employeeId], references: [id])
  roleId        Int        @map("role_id")
  role          Role       @relation(fields: [roleId], references: [id])
  username      String     @unique
  passwordHash  String     @map("password_hash")
  isActive      Boolean    @default(true) @map("is_active")
  lastLoginAt   DateTime?  @map("last_login_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  deletedAt     DateTime?  @map("deleted_at")

  sessions      UserSession[]
  otpTokens     OtpToken[]
  activityLogs  ActivityLog[]
  verifiedAttendances Attendance[] @relation("AttendanceVerifier")

  @@index([roleId])
  @@map("users")
}

model UserSession {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique @map("token_hash")
  rememberMe  Boolean   @default(false) @map("remember_me")
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("user_sessions")
}

model OtpToken {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash    String    @map("code_hash")
  purpose     String    // login | reset_password
  expiresAt   DateTime  @map("expires_at")
  consumedAt  DateTime? @map("consumed_at")
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId, purpose])
  @@map("otp_tokens")
}

// ============ MASTER WILAYAH ============

model Provinsi {
  id        Int         @id
  name      String
  kabupaten Kabupaten[]
  @@map("provinsi")
}

model Kabupaten {
  id          Int         @id
  name        String
  provinsiId  Int         @map("provinsi_id")
  provinsi    Provinsi    @relation(fields: [provinsiId], references: [id])
  kecamatan   Kecamatan[]
  employeesBornHere Employee[] @relation("EmployeeBirthPlace")
  @@index([name])
  @@map("kabupaten")
}

model Kecamatan {
  id           Int         @id
  name         String
  kabupatenId  Int         @map("kabupaten_id")
  kabupaten    Kabupaten   @relation(fields: [kabupatenId], references: [id])
  kelurahan    Kelurahan[]
  @@index([name])
  @@map("kecamatan")
}

model Kelurahan {
  id           Int         @id
  name         String
  kecamatanId  Int         @map("kecamatan_id")
  kecamatan    Kecamatan   @relation(fields: [kecamatanId], references: [id])
  employees    Employee[]
  @@index([name])
  @@map("kelurahan")
}

// ============ MASTER PEGAWAI ============

model Position {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  employees Employee[]
  @@map("positions")
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  employees Employee[]
  @@map("departments")
}

model Office {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  latitude    Decimal  @db.Decimal(10, 7)
  longitude   Decimal  @db.Decimal(10, 7)
  attendancesIn  Attendance[] @relation("CheckinOffice")
  attendancesOut Attendance[] @relation("CheckoutOffice")
  @@map("offices")
}

enum EmploymentType {
  kontrak
  tetap
  magang
}

enum MaritalStatus {
  kawin
  tidak_kawin
}

enum Gender {
  pria
  wanita
}

model Employee {
  id                  Int             @id @default(autoincrement())
  nip                 String          @unique
  fullName            String          @map("full_name")
  email               String          @unique
  phone               String
  photoPath           String?         @map("photo_path")

  addressKelurahanId  Int?            @map("address_kelurahan_id")
  addressKelurahan    Kelurahan?      @relation(fields: [addressKelurahanId], references: [id])
  addressDetail       String?         @map("address_detail")
  latitude            Decimal?        @db.Decimal(10, 7)
  longitude           Decimal?        @db.Decimal(10, 7)

  birthKabupatenId    Int?            @map("birth_kabupaten_id")
  birthKabupaten      Kabupaten?      @relation("EmployeeBirthPlace", fields: [birthKabupatenId], references: [id])
  birthDate           DateTime?       @map("birth_date") @db.Date
  maritalStatus       MaritalStatus?  @map("marital_status")
  childrenCount       Int             @default(0) @map("children_count")

  joinDate            DateTime        @map("join_date") @db.Date
  positionId          Int             @map("position_id")
  position            Position        @relation(fields: [positionId], references: [id])
  departmentId        Int             @map("department_id")
  department          Department      @relation(fields: [departmentId], references: [id])
  employmentType      EmploymentType  @map("employment_type")
  gender              Gender?

  isActive            Boolean         @default(true) @map("is_active")

  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  deletedAt           DateTime?       @map("deleted_at")

  educations          EmployeeEducation[]
  attendances         Attendance[]
  transportAllowances TransportAllowance[]
  leaveQuotas         LeaveQuota[]
  user                User?

  @@index([fullName])
  @@index([nip])
  @@index([employmentType])
  @@map("employees")
}

model EmployeeEducation {
  id           Int      @id @default(autoincrement())
  employeeId   Int      @map("employee_id")
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  level        String   // SD | SMP | SMA | D3 | S1 | S2
  institution  String
  major        String?
  yearStart    Int?     @map("year_start")
  yearEnd      Int?     @map("year_end")
  sortOrder    Int      @default(0) @map("sort_order")

  @@index([employeeId])
  @@map("employee_educations")
}

// ============ TUNJANGAN TRANSPORT ============

model TransportSetting {
  id              Int      @id @default(autoincrement())
  baseFarePerKm   Decimal  @map("base_fare_per_km") @db.Decimal(12, 2)
  effectiveFrom   DateTime @map("effective_from") @db.Date
  createdById     Int?     @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([effectiveFrom])
  @@map("transport_settings")
}

model TransportAllowance {
  id              Int      @id @default(autoincrement())
  employeeId      Int      @map("employee_id")
  employee        Employee @relation(fields: [employeeId], references: [id])
  periodYear      Int      @map("period_year")
  periodMonth     Int      @map("period_month")
  distanceKmRaw   Decimal  @map("distance_km_raw") @db.Decimal(6, 2)
  distanceKmUsed  Int      @map("distance_km_used")
  workingDays     Int      @map("working_days")
  baseFare        Decimal  @map("base_fare") @db.Decimal(12, 2)
  amount          Decimal  @db.Decimal(14, 2)
  eligible        Boolean
  reason          String?
  computedAt      DateTime @default(now()) @map("computed_at")

  @@unique([employeeId, periodYear, periodMonth])
  @@map("transport_allowances")
}

// ============ PRESENSI ============

model LeaveQuota {
  id                  Int      @id @default(autoincrement())
  employeeId          Int      @map("employee_id")
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year                Int
  cutiQuota           Decimal  @map("cuti_quota") @db.Decimal(4, 1)
  izinQuota           Decimal  @map("izin_quota") @db.Decimal(4, 1)
  unpaidLeaveQuota    Decimal  @map("unpaid_leave_quota") @db.Decimal(4, 1)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([employeeId, year])
  @@map("leave_quotas")
}

enum AttendanceKind {
  hadir
  cuti
  izin
  unpaid_leave
}

enum AttendanceStatus {
  terpenuhi
  tidak_terpenuhi
}

enum VerificationStatus {
  pending
  disetujui
  ditolak
}

enum VerifierRole {
  lead
  manager
  hrd
}

enum AttendanceSource {
  import_excel
  manual
}

model Attendance {
  id                  Int       @id @default(autoincrement())
  employeeId          Int       @map("employee_id")
  employee            Employee  @relation(fields: [employeeId], references: [id])
  date                DateTime  @db.Date

  checkInAt           DateTime? @map("check_in_at")
  checkOutAt          DateTime? @map("check_out_at")
  checkInOfficeId     Int?      @map("check_in_office_id")
  checkInOffice       Office?   @relation("CheckinOffice", fields: [checkInOfficeId], references: [id])
  checkOutOfficeId    Int?      @map("check_out_office_id")
  checkOutOffice      Office?   @relation("CheckoutOffice", fields: [checkOutOfficeId], references: [id])

  kehadiran           AttendanceKind     @default(hadir)
  durationHours       Decimal            @default(0) @map("duration_hours") @db.Decimal(4, 1)
  status              AttendanceStatus   @default(tidak_terpenuhi)
  lateMinutes         Int                @default(0) @map("late_minutes")
  isHalfday           Boolean            @default(false) @map("is_halfday")

  verifikasi          VerificationStatus @default(pending)
  verifikator         VerifierRole?
  verifikatorUserId   Int?               @map("verifikator_user_id")
  verifikatorUser     User?              @relation("AttendanceVerifier", fields: [verifikatorUserId], references: [id])

  keterangan          String?
  source              AttendanceSource @default(manual)

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@unique([employeeId, date])
  @@index([date])
  @@map("attendances")
}

enum ImportStatus {
  queued
  processing
  done
  failed
}

model AttendanceImport {
  id            Int          @id @default(autoincrement())
  userId        Int          @map("user_id")
  filePath      String       @map("file_path")
  periodYear    Int          @map("period_year")
  periodMonth   Int          @map("period_month")
  status        ImportStatus @default(queued)
  totalRows     Int          @default(0) @map("total_rows")
  successRows   Int          @default(0) @map("success_rows")
  failedRows    Int          @default(0) @map("failed_rows")
  errorLog      Json?        @map("error_log")
  createdAt     DateTime     @default(now()) @map("created_at")
  finishedAt    DateTime?    @map("finished_at")

  @@map("attendance_imports")
}

// ============ AUDIT LOG ============

model ActivityLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  user        User?    @relation(fields: [userId], references: [id])
  username    String?
  action      String   // login | logout | create | read | update | delete
  module      String   // Login | Pegawai | Presensi | Tunjangan | User | ...
  description String?
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([userId])
  @@index([module])
  @@map("activity_logs")
}
